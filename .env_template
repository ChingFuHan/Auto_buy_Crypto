# Auto_buy_Crypto 環境設定模板
#
# 使用方式：
# 1. 這是一份範本，不含任何真實密鑰。
# 2. 實際執行程式時，程式讀取的是專案根目錄的 .env。
# 3. 每一行格式都是 KEY=value。
# 4. 以 # 開頭的行是註解，不會被程式讀取。
# 5. 不要在沒有 # 的行寫中文說明，否則可能被 dotenv 當成設定內容。
# 6. 修改 .env 後必須重新啟動 main.py，新設定才會生效。
#
# 重要風險：
# - TESTNET=false 且 ENABLE_LIVE_TRADING=true 時，代表正式盤真實下單。
# - FUNCTION_TEST_MODE=false 時，不再只限制單一測試幣種，符合條件的候選幣都可能下單。
# - STRATEGY_INTERVAL=15m 時，訊號會比 3m 慢，但噪音通常較少；門檻仍需另外觀察校準。


# =============================================================================
# 交易所 API 密鑰
# =============================================================================

# Binance Futures API key。
# 正式盤 / testnet 都需要填對應環境的 API key。
# 這裡請勿填範例文字，也不要把真實 key commit 到 git。
API_KEY=

# Binance Futures API secret。
# 權限建議只開必要 futures 權限；不要開不需要的提款權限。
API_SECRET=


# =============================================================================
# 執行模式與真實下單開關
# =============================================================================

# 是否使用 Binance Futures Testnet。
# true  = 測試網，不是真實資金。
# false = 正式盤，會連到真實 Binance Futures。
TESTNET=true

# 是否允許送出真實交易指令。
# false = 不送真單，只做資料同步、訊號判斷、log / Telegram 通知。
# true  = 允許送單；若 TESTNET=false，代表正式盤真實下單。
ENABLE_LIVE_TRADING=false

# 功能測試模式。
# true  = 只允許 FUNCTION_TEST_SYMBOL 真的下單，其他幣就算觸發也會被攔下。
# false = 不限制單一測試幣，所有符合策略條件的候選幣都可下單。
FUNCTION_TEST_MODE=true

# 功能測試模式允許下單的幣種。
# 只有 FUNCTION_TEST_MODE=true 時才有保護效果。
# 即使 BTCUSDT 在大幣排除清單內，function test mode 仍會把它加入測試評估。
FUNCTION_TEST_SYMBOL=BTCUSDT

# 正式盤小額全自動範例：
# TESTNET=false
# ENABLE_LIVE_TRADING=true
# FUNCTION_TEST_MODE=false


# =============================================================================
# Telegram 通知
# =============================================================================

# 是否啟用 Telegram 通知。
# true  = 發送啟動、模式、訊號、下單、止損、錯誤等通知。
# false = 不發 Telegram，但程式仍會寫 log。
TELEGRAM_ENABLED=true

# Telegram bot token。
# 從 BotFather 建立 bot 後取得。
TELEGRAM_BOT_TOKEN=

# Telegram chat id。
# 可以是個人 chat，也可以是群組 chat。
TELEGRAM_CHAT_ID=


# =============================================================================
# Heartbeat / 程式存活回報
# =============================================================================
#
# main.py run 期間是否每隔一段時間發 Telegram 訊息，告訴你「程式還活著」。
# 訊息會帶 uptime / 持倉數量 / 主週期 / 是否正式盤 / 監控幣數。
# 等級為 INFO（disable_notification=true），手機通常不會響鈴，只進對話框，
# 避免每次都被打擾；若 heartbeat 突然不再進來，就代表程式可能已經掛掉。
#
# true  = 啟用 heartbeat 通知。
# false = 關閉。
HEARTBEAT_ENABLED=true

# 兩次 heartbeat 之間的秒數。
# 預設 900 = 15 分鐘。最小允許 60 秒；太短可能被 Telegram 限流。
# 建議：15-30 分鐘。
HEARTBEAT_INTERVAL_SECONDS=900


# =============================================================================
# PostgreSQL 資料庫
# =============================================================================

# PostgreSQL 主機。
# Windows host / VM / Docker 環境可能不同，依你的 DB 實際位置填。
DB_HOST=127.0.0.1

# PostgreSQL port，預設通常是 5432。
DB_PORT=5432

# PostgreSQL 使用者。
DB_USER=

# PostgreSQL 密碼。
# 請勿 commit 真實密碼。
DB_PASS=

# 專案使用的資料庫名稱。
DB_NAME=daily


# =============================================================================
# 主策略週期
# =============================================================================

# 主策略使用的 K 線週期。
# 支援值：
# - 3m  ：使用 public.semi_auto_price_future_3m 和 data/inprogress_3m.csv。
# - 15m ：使用 public.semi_auto_price_future_15m 和 data/inprogress_15m.csv。
#
# 切成 15m 後會一起影響：
# - Binance WebSocket 訂閱週期
# - REST backfill / reconnect catch-up 週期
# - DB seed 讀取資料表
# - in-progress 暫存 CSV
# - SignalEngine 進場訊號判斷
# - fallback stop 的 CONTRACT_PRICE 觸發資料來源
#
# 注意：
# - 15m 資料表必須先補齊資料。
# - 15m 訊號會比較慢，止損 low 也可能比 3m 更寬。
# - 3m 與 15m 有各自獨立的訊號門檻，避免混淆。
STRATEGY_INTERVAL=15m


# =============================================================================
# 倉位大小與最多同時持倉
# =============================================================================

# 倉位大小模式。
# FIXED_NOTIONAL = 每筆使用固定名目金額 TARGET_NOTIONAL_USDT。
# BALANCE_SPLIT  = 依可用餘額、最大槓桿、剩餘持倉槽位動態分配。
POSITION_SIZING_MODE=FIXED_NOTIONAL

# 每筆目標名目金額，單位 USDT。
# 只有 POSITION_SIZING_MODE=FIXED_NOTIONAL 時主要使用這個值。
# 例：50 代表每筆約 50 USDT 名目，不是 50 USDT 保證金。
TARGET_NOTIONAL_USDT=50

# 同時最多持有幾個不同幣種。
# 達到上限時，新訊號會直接跳過，不會排隊等待。
MAX_CONCURRENT_POSITIONS=10

# 動態分配資金範例：
# POSITION_SIZING_MODE=BALANCE_SPLIT
# MAX_CONCURRENT_POSITIONS=5
#
# 注意：
# - BALANCE_SPLIT 會盡量使用可用保證金與該幣最大槓桿做分配。
# - 不建議在沒有充分觀察前直接用大資金跑。


# =============================================================================
# 交易對篩選
# =============================================================================

# 黑名單。逗號分隔。
# 被列入的 symbol 永遠不參與候選。
# 例：SYMBOL_BLACKLIST=BTCUSDT,ETHUSDT
SYMBOL_BLACKLIST=

# 白名單。逗號分隔。
# 若填入，通常表示只允許這些 symbol 進候選。
# 留空代表不使用白名單限制。
SYMBOL_WHITELIST=

# 大幣排除清單。
# 主策略是小幣 / 新幣 first-pump 取向，因此預設排除大幣。
EXCLUDED_BIG_CAPS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT


# =============================================================================
# 止損設定
# =============================================================================

# 原生 stop order 失敗時的重試次數。
STOP_ORDER_RETRY_COUNT=3

# Binance 原生 STOP_MARKET 的觸發價格來源。
# CONTRACT_PRICE = 用合約最新價格觸發。
# MARK_PRICE     = 用標記價格觸發。
#
# 注意：
# - CONTRACT_PRICE 比較貼近成交價格，但極端波動下可能更敏感。
# - MARK_PRICE 比較不容易被短暫插針觸發，但可能觸發較慢。
STOP_WORKING_TYPE=CONTRACT_PRICE

# 止損價格模式。
# IN_PROGRESS_INTERVAL_LOW = 使用入場當下主週期 in-progress K 線 low。
# NOTIONAL_RISK_PCT        = 用成交均價按 STOP_NOTIONAL_RISK_PCT 計算止損。
#
# 推薦初始觀察：
# - 若想讓止損跟著 K 線結構：使用 IN_PROGRESS_INTERVAL_LOW。
# - 若想人工固定風險比例：使用 NOTIONAL_RISK_PCT。
STOP_PRICE_MODE=IN_PROGRESS_INTERVAL_LOW

# 名目風險比例止損範例。
# 若 STOP_PRICE_MODE=NOTIONAL_RISK_PCT：
# - 0.20 代表做多止損約在 entry * (1 - 0.20)，也就是約 80% entry。
# - 0.15 代表做多止損約在 entry * 0.85。
# - 0.50 代表做多止損約在 entry * 0.50，距離非常寬。
#
# 要切換成名目比例止損，可改成：
# STOP_PRICE_MODE=NOTIONAL_RISK_PCT
# STOP_NOTIONAL_RISK_PCT=0.20
STOP_NOTIONAL_RISK_PCT=0.50


# =============================================================================
# Binance server time / API retry
# =============================================================================

# 是否啟用 Binance server time 校時。
# 建議保持 true，避免 timestamp 偏差造成下單失敗。
SERVER_TIME_SYNC_ENABLED=true

# 每隔幾秒重新校時。
SERVER_TIME_RESYNC_INTERVAL_SECONDS=300

# 允許的最大 server time offset，單位毫秒。
MAX_SERVER_TIME_OFFSET_MS=5000

# Binance API recvWindow，單位毫秒。
RECV_WINDOW=5000

# API 自動重試上限。
# 依 god_rule，不應無限重試。
API_RETRY_MAX_ATTEMPTS=3

# API retry 起始等待秒數。
API_RETRY_BACKOFF_BASE_SECONDS=1

# API retry 最大等待秒數。
API_RETRY_BACKOFF_MAX_SECONDS=8


# =============================================================================
# Backfill / 啟動時補資料
# =============================================================================

# 回補天數。
# 15m 已另行補過近 120 天資料；正式 run 時通常不需要每次啟動都大回補。
BACKFILL_DAYS=90

# Binance kline 單次請求最大筆數。
BACKFILL_LIMIT=1000

# 回補並行數。
# 設太高容易遇到 Binance 429。
# 若共用 IP 或 VM 環境不穩，建議 1。
BACKFILL_CONCURRENCY=1

# 程式啟動時是否先跑 backfill。
# false = 啟動較快，使用既有 DB 資料和 WebSocket 接續。
# true  = 啟動時先補資料，但可能耗時且可能遇到 429。
STARTUP_BACKFILL_ENABLED=false


# =============================================================================
# 訊號門檻
# =============================================================================
#
# 注意：
# - STRATEGY_INTERVAL=3m  時只讀 SIGNAL_3M_*。
# - STRATEGY_INTERVAL=15m 時只讀 SIGNAL_15M_*。
# - 兩組參數彼此獨立，不會互相套用。
# - 15m 的合理門檻尚未長期校準，切 15m 正式盤時請小額觀察。

# --- 3m 訊號門檻 ---
#
# 3m_LOOKBACK：
# 壓縮 / 成交量計算使用最近幾根 finalized 3m K 線。
# 3m 下 20 根約 60 分鐘。
SIGNAL_3M_LOOKBACK=20

# 3m_BREAKOUT_LOOKBACK：
# 當前 in-progress 3m high 要突破最近幾根 finalized 3m high。
SIGNAL_3M_BREAKOUT_LOOKBACK=12

# 3m 平均 range% 壓縮上限。
# 數值越小，要求越壓縮，訊號越少。
SIGNAL_3M_COMPRESSION_ATR_PCT_MAX=0.015

# 3m 最近 lookback 區間總 range% 上限。
# 數值越小，越不追已經拉開的盤。
SIGNAL_3M_COMPRESSION_RANGE_PCT_MAX=0.035

# 當前 in-progress 3m 成交量 / 最近 finalized 3m 平均成交量。
# 2.0 代表至少要是平均量 2 倍。
SIGNAL_3M_VOLUME_MULTIPLE=2.0

# 當前 in-progress 3m close 相對上一根 finalized 3m close 的漲幅。
# 0.017 代表至少約 1.7%。調升原因：SFPUSDT/TRUMPUSDT 實測觸發後收盤滑落至 0.0144~0.0146，加緩衝至 0.017。
SIGNAL_3M_RETURN_PCT_MIN=0.017

# 當前 in-progress 3m 漲幅過熱上限。
# 超過代表可能已經瞬間過熱，避免高點追入。
SIGNAL_3M_OVERHEAT_LIMIT_PCT=0.060


# --- 15m 訊號門檻 ---
#
# 15m_LOOKBACK：
# 壓縮 / 成交量計算使用最近幾根 finalized 15m K 線。
# 15m 下 20 根約 300 分鐘。
SIGNAL_15M_LOOKBACK=20

# 15m_BREAKOUT_LOOKBACK：
# 當前 in-progress 15m high 要突破最近幾根 finalized 15m high。
SIGNAL_15M_BREAKOUT_LOOKBACK=12

# 15m 平均 range% 壓縮上限。
# 注意：這裡先給與 3m 相同的初始值，正式盤需小額觀察後再校準。
SIGNAL_15M_COMPRESSION_ATR_PCT_MAX=0.015

# 15m 最近 lookback 區間總 range% 上限。
# 15m 的 lookback 時間較長，這個值可能需要比 3m 更寬或重新回測。
SIGNAL_15M_COMPRESSION_RANGE_PCT_MAX=0.035

# 當前 in-progress 15m 成交量 / 最近 finalized 15m 平均成交量。
SIGNAL_15M_VOLUME_MULTIPLE=2.0

# 當前 in-progress 15m close 相對上一根 finalized 15m close 的漲幅。
# 0.017 與 3m 門檻同步調升，實際 15m 回測校準待後續觀察。
SIGNAL_15M_RETURN_PCT_MIN=0.017

# 當前 in-progress 15m 漲幅過熱上限。
SIGNAL_15M_OVERHEAT_LIMIT_PCT=0.060


# --- 共同風控門檻 ---
#
# 最近 5 根 finalized 主週期的總 range% 上限。
# 超過代表可能已經延伸過多，避免追高。
SIGNAL_PRIOR_RUNUP_LIMIT_PCT=0.040

# 最近連續上漲 finalized K 線根數上限。
# 超過代表可能已經連漲一段，避免追後段。
SIGNAL_MAX_RECENT_GREEN_BARS=3

# 每個 symbol 從 DB seed 到記憶體的 K 線數量。
# 必須大於等於 lookback / breakout lookback。
KLINE_SEED_LIMIT=90


# =============================================================================
# 背景任務週期
# =============================================================================

# 多久重新抓交易所 symbol universe，單位秒。
SYMBOL_REFRESH_INTERVAL_SECONDS=900

# 多久同步一次帳戶持倉 / open orders，單位秒。
POSITION_REFRESH_INTERVAL_SECONDS=30

# fallback stop 輪詢間隔，單位秒。
FALLBACK_POLL_INTERVAL_SECONDS=1

# in-progress CSV flush 間隔，單位秒。
STAGING_FLUSH_INTERVAL_SECONDS=1

# 單條 Binance combined websocket 最多 streams。
# Binance 有 stream 數量限制，通常不要超過 200~300。
WS_MAX_STREAMS_PER_CONNECTION=200

# websocket 斷線後最多重連次數。
WS_MAX_RECONNECT_ATTEMPTS=3


# =============================================================================
# Binance endpoint override
# =============================================================================

# 通常留空即可。
# 只有在測試 proxy / mock server / 特殊 endpoint 時才填。
BINANCE_REST_BASE_URL=
BINANCE_WS_BASE_URL=


# =============================================================================
# Log
# =============================================================================

# 可用值通常為 DEBUG / INFO / WARNING / ERROR。
# 正式盤建議 INFO。
LOG_LEVEL=INFO
